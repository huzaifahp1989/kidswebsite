# Copy this file to `.env` (for local dev) and set real values.
# Vite loads `.env` / `.env.local` at startup. Restart the dev server after changes.

# Supabase project configuration
VITE_SUPABASE_URL=https://jlqrbbqsuksncrxjcmbc.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

VITE_QURAN_API_TOKEN=YOUR_QURAN_API_TOKEN
VITE_QURAN_API_CLIENT_ID=YOUR_QURAN_API_CLIENT_ID

# Admin gating (recommended)
# Exact email allowed into admin pages via AdminGuard
VITE_ADMIN_EMAIL=admin@example.com

# Optional Netlify backend for messages
VITE_USE_BACKEND=false

# Setup notes
# 1. In Supabase → Authentication: enable Email/Password
# 2. Add your site URL (e.g. imediackids.com) to Redirect URLs
# 3. Run supabase/schema.sql in the Supabase SQL editor to create tables
# 4. Set VITE_SUPABASE_ANON_KEY from Supabase → Project Settings → API
