{
  "name": "base44-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:gh": "powershell -NoProfile -Command \"$env:VITE_BASE_PATH='/imediaweb/'; vite build; Copy-Item -Path 'dist/index.html' -Destination 'dist/404.html' -Force\"",
    "build:gh-domain": "powershell -NoProfile -Command \"$env:VITE_BASE_PATH='/'; vite build; Copy-Item -Path 'dist/index.html' -Destination 'dist/404.html' -Force\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:docs": "powershell -NoProfile -Command \"$env:VITE_BASE_PATH='/'; vite build --outDir docs; Copy-Item -Path 'docs/index.html' -Destination 'docs/404.html' -Force\"",
    "build:docs-domain": "powershell -NoProfile -Command \"$env:VITE_BASE_PATH='/'; vite build --outDir docs; Copy-Item -Path 'docs/index.html' -Destination 'docs/404.html' -Force; Set-Content -Path 'docs/CNAME' -Value 'imediackids.com'\"",
    "preview:docs": "vite preview --outDir docs",
    "predeploy": "npm run build:gh-domain",
    "deploy": "gh-pages -d dist --cname imediackids.com",
    "predeploy:gh": "npm run build:gh",
    "deploy:gh": "gh-pages -d dist",
    "predeploy:docs": "npm run build:docs-domain",
    "deploy:docs": "gh-pages -d docs --cname imediackids.com",
    "split:asma": "node scripts/split-asma-audio.js",
    "test:validation": "node scripts/tests/validation-inline.test.js",
    "test:leaderboard:unit": "node scripts/tests/leaderboard.unit.test.js",
    "test:leaderboard:integration": "node scripts/tests/leaderboard.integration.test.js",
    "test:leaderboard:e2e": "node scripts/tests/leaderboard.e2e.test.js"
  },
  "dependencies": {
    "@base44/sdk": "^0.1.2",
    "@dataconnect/admin-generated": "file:src/dataconnect-admin-generated",
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "@hookform/resolvers": "^4.1.2",
    "@netlify/functions": "^5.1.0",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-aspect-ratio": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.3",
